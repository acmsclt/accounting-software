# Application
APP_NAME="AccountingPro"
APP_ENV=production
APP_URL=http://localhost
APP_KEY=base64:CHANGE_THIS_TO_A_RANDOM_32_CHAR_STRING
APP_DEBUG=false
APP_TIMEZONE=UTC
APP_LOCALE=en

# Database
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=accounting_saas
DB_USERNAME=root
DB_PASSWORD=

# JWT
JWT_SECRET=CHANGE_THIS_TO_A_RANDOM_64_CHAR_SECRET
JWT_EXPIRY=3600
JWT_REFRESH_EXPIRY=604800

# Email (SMTP)
MAIL_DRIVER=smtp
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your@email.com
MAIL_PASSWORD=your_app_password
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=noreply@accountingpro.com
MAIL_FROM_NAME="AccountingPro"

# SendGrid (alternative)
SENDGRID_API_KEY=

# Twilio (SMS)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# Stripe
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# Razorpay
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# PayPal
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_MODE=sandbox

# Webhook
WEBHOOK_SECRET=CHANGE_THIS_TO_A_RANDOM_SECRET
WEBHOOK_TIMEOUT=30
WEBHOOK_MAX_RETRIES=3

# Session
SESSION_DRIVER=file
SESSION_LIFETIME=7200

# File Storage
STORAGE_PATH=/uploads

# Exchange Rate API
EXCHANGE_RATE_API_KEY=
EXCHANGE_RATE_BASE_CURRENCY=USD

# Logging
LOG_LEVEL=error
LOG_PATH=/logs
